DATABASE_URL=postgres://axiom:axiom@localhost:5432/axiom_arb
AXIOM_MODE=paper

# Current app-live neg-risk operator inputs.
# JSON values should be single-line payloads.
AXIOM_NEG_RISK_LIVE_TARGETS=
AXIOM_NEG_RISK_LIVE_APPROVED_FAMILIES=
AXIOM_NEG_RISK_LIVE_READY_FAMILIES=
AXIOM_LOCAL_SIGNER_CONFIG=

# Manual operator workflow only. When set to 1, neg-risk is forced onto the
# shadow path and AXIOM_POLYMARKET_SOURCE_CONFIG becomes required.
AXIOM_REAL_USER_SHADOW_SMOKE=0
AXIOM_POLYMARKET_SOURCE_CONFIG=

# Legacy crates/config defaults still used by some library/config surfaces.
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_DATA_API_HOST=https://data-api.polymarket.com
POLY_RELAYER_HOST=https://relayer-v2.polymarket.com
POLY_SIGNATURE_TYPE=EOA
